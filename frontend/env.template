# Next.js Environment Configuration Template
# Copy this file to .env.local and update the values

# Next.js Configuration
NEXT_PUBLIC_APP_NAME=Wedding Website
NEXT_PUBLIC_APP_DESCRIPTION=Beautiful wedding website with RSVP management

# API Configuration
# Server-side API URL (not exposed to browser)
API_URL=http://localhost:3001

# Environment
NODE_ENV=development

# Build Configuration
ANALYZE=false

# Google Maps API Configuration
# Required for map functionality (accommodations and venue maps)
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Make sure to enable: Maps JavaScript API, Places API, Geocoding API, Directions API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Maps API Configuration (optional)
# NEXT_PUBLIC_GOOGLE_MAPS_REGION=FR
# NEXT_PUBLIC_GOOGLE_MAPS_LANGUAGE=fr

# Analytics (optional - for future use)
# NEXT_PUBLIC_GA_TRACKING_ID=your-google-analytics-id

# Wedding Information (for SEO and metadata)
NEXT_PUBLIC_COUPLE_NAMES=Ariane & Timothe
NEXT_PUBLIC_WEDDING_DATE=2024-06-15
NEXT_PUBLIC_WEDDING_LOCATION=Château de Malmaison, France
